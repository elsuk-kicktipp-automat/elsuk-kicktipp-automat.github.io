---
import { SITE_VERSION } from '../lib/siteVersion.mjs';

const { title = 'Der Automat' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { href: `${base}/`, label: 'Spieltag' },
  { href: `${base}/archiv/`, label: 'Archiv' },
  { href: `${base}/bilanz/`, label: 'Bilanz' },
  { href: `${base}/wie-ich-denke/`, label: 'Wie ich denke' },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0c0e13" />
    <meta http-equiv="cache-control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <meta name="site-version" content={SITE_VERSION} />
    <title>{title} · Der Automat</title>
    <meta
      name="description"
      content="Der Automat: ein statistischer KI-Tipper für die Kicktipp-Runde – transparent, versiegelt, nachrechenbar."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="b7788806-f762-4f1d-902e-fce55d0b8c04"></script>
    <script is:inline define:vars={{ base, currentVersion: SITE_VERSION }}>
      (() => {
        const key = 'der-automat-site-version';
        const reloadKey = `${key}-reloaded`;
        const url = `${base}/site-version.json?t=${Date.now()}`;
        fetch(url, { cache: 'no-store' })
          .then((response) => (response.ok ? response.json() : null))
          .then((data) => {
            const latest = data && data.version;
            if (!latest) return;
            sessionStorage.setItem(key, latest);
            if (latest !== currentVersion && sessionStorage.getItem(reloadKey) !== latest) {
              sessionStorage.setItem(reloadKey, latest);
              location.reload();
            }
          })
          .catch(() => {});
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <div class="glows" aria-hidden="true">
        <div class="glow glow-lime-tl"></div>
        <div class="glow glow-blue-r"></div>
        <div class="glow glow-lime-b"></div>
        <div class="streak streak-lime"></div>
        <div class="streak streak-white"></div>
      </div>

      <div class="container">
        <header class="site-header">
          <a class="brand" href={`${base}/`}>
            <span class="brand-mark"><span>A</span></span>
            <span class="brand-name">Der Automat</span>
          </a>
          <nav class="site-nav">
            {nav.map((item) => (
              <a href={item.href} class:list={['nav-link', { active: current === item.href }]}>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </header>

        <main>
          <slot />
        </main>

        <footer class="site-footer">
          Maschinell getippt, menschlich verlierbar. Quellcode &amp; Daten:
          <a href="https://github.com/elsuk-kicktipp-automat/elsuk-kicktipp-automat.github.io">GitHub</a>
        </footer>
      </div>
    </div>
  </body>
</html>

<style>
  .page { min-height: 100vh; position: relative; }

  .glows { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
  .glow { position: absolute; }
  .glow-lime-tl {
    top: -220px; left: -140px; width: 760px; height: 620px;
    background: radial-gradient(closest-side, rgba(212, 255, 63, 0.2), transparent 70%);
    animation: glowDrift 14s ease-in-out infinite;
  }
  .glow-blue-r {
    top: 260px; right: -240px; width: 820px; height: 700px;
    background: radial-gradient(closest-side, rgba(63, 140, 255, 0.15), transparent 70%);
    animation: glowDrift 18s ease-in-out infinite reverse;
  }
  .glow-lime-b {
    bottom: -200px; left: 20%; width: 700px; height: 560px;
    background: radial-gradient(closest-side, rgba(212, 255, 63, 0.09), transparent 70%);
  }
  .streak { position: absolute; transform: skewX(-18deg); }
  .streak-lime { top: 380px; left: -80px; width: 340px; height: 1600px; background: rgba(212, 255, 63, 0.05); }
  .streak-white { top: 120px; right: 16%; width: 200px; height: 1800px; background: rgba(255, 255, 255, 0.02); }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1160px;
    margin: 0 auto;
    padding: 20px 20px 0;
  }

  .site-header {
    position: sticky;
    top: 12px;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 24px;
    border-radius: var(--r-header);
    background: var(--glass-bg-strong);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-highlight), 0 14px 38px rgba(0, 0, 0, 0.4);
  }
  .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text); }
  .brand-mark {
    width: 30px; height: 30px;
    background: var(--lime);
    transform: skewX(-12deg);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 24px rgba(212, 255, 63, 0.4);
  }
  .brand-mark span {
    transform: skewX(12deg);
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--bg);
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 19px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .site-nav {
    display: flex; flex-wrap: wrap; gap: 6px;
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .nav-link { text-decoration: none; padding: 8px 16px; color: var(--text-muted); transition: color 0.2s; }
  .nav-link:hover { color: var(--text); }
  .nav-link.active {
    background: var(--lime);
    color: var(--bg);
    transform: skewX(-12deg);
    box-shadow: 0 0 20px rgba(212, 255, 63, 0.3);
  }
  .nav-link.active span { display: inline-block; transform: skewX(12deg); }

  .site-footer {
    margin-top: 36px;
    padding: 18px 4px 26px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .site-footer a { color: var(--lime); font-weight: 600; text-decoration: none; }
  .site-footer a:hover { text-decoration: underline; }
</style>

<style is:global>
  @keyframes riseIn {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes glowDrift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, 20px); }
  }

  :root {
    color-scheme: dark;
    --font-display: 'Anton', sans-serif;
    --font-body: 'Archivo', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --font-mono: ui-monospace, 'SF Mono', 'Cascadia Code', 'JetBrains Mono', Consolas, 'Liberation Mono', monospace;
    --font-sans: var(--font-body);

    /* Broadcast-Glass Farbpalette */
    --bg: #0c0e13;
    --text: #eef1f7;
    --text-muted: #a7aebd;
    --text-body: #b7bdcc;
    --muted: var(--text-muted);

    --lime: #d4ff3f;
    --gold: #e8c96a;
    --red: #ff4d5e;
    --blue: #3f8cff;

    /* Alt-Aliase: von archiv/bilanz weiterverwendet, jetzt auf die neue Palette gemappt */
    --accent: var(--lime);
    --accent-strong: var(--lime);
    --accent-glow: rgba(212, 255, 63, 0.35);
    --accent-soft: rgba(212, 255, 63, 0.14);
    --series-blue: var(--blue);
    --series-amber: var(--gold);
    --series-red: var(--red);
    --series-gray: #8b93a5;
    --p4: var(--gold);
    --p3: var(--gold);
    --p2: var(--gold);
    --p0: var(--red);

    --glass-bg: rgba(255, 255, 255, 0.05);
    --glass-bg-strong: rgba(18, 21, 30, 0.72);
    --glass-border: rgba(255, 255, 255, 0.12);
    --glass-highlight: inset 0 1px 0 rgba(255, 255, 255, 0.15);
    --surface: var(--glass-bg);
    --surface-2: rgba(255, 255, 255, 0.03);
    --surface-solid: #12151e;
    --border: var(--glass-border);

    --shadow-card: 0 20px 48px rgba(0, 0, 0, 0.45);
    --shadow-card-hover: 0 30px 64px rgba(0, 0, 0, 0.55), 0 0 44px rgba(212, 255, 63, 0.12);
    --glow-lime: 0 0 30px rgba(212, 255, 63, 0.35);

    --r-card: 20px;
    --r-panel: 16px;
    --r-header: 18px;
    --r-badge: 8px;
  }

  * { box-sizing: border-box; }

  html, body { margin: 0; padding: 0; background: var(--bg); }
  body {
    min-height: 100vh;
    color: var(--text);
    font-family: var(--font-body);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::selection { background: var(--accent-glow); color: var(--text); }
  * { scrollbar-color: var(--lime) transparent; scrollbar-width: thin; }
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--lime); }

  a { color: var(--lime); }
  a:focus-visible, button:focus-visible, [tabindex]:focus-visible, summary:focus-visible {
    outline: 2px solid var(--lime);
    outline-offset: 2px;
    border-radius: 4px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 7.5vw, 76px);
    line-height: 1.05;
    text-transform: uppercase;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.01em;
    margin: 44px 0 18px;
    color: var(--text);
    text-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
  }
  h1 .accent { color: var(--lime); text-shadow: 0 0 40px rgba(212, 255, 63, 0.45); }

  h2 {
    position: relative;
    font-family: var(--font-display);
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-top: 2.4rem;
    margin-bottom: 0.8rem;
    padding-left: 0.85rem;
    color: var(--text);
  }
  h2::before {
    content: '';
    position: absolute;
    left: 0; top: 0.2em;
    width: 5px; height: 0.75em;
    background: var(--lime);
    transform: skewX(-12deg);
    box-shadow: 0 0 12px rgba(212, 255, 63, 0.4);
  }

  .muted { color: var(--text-muted); }

  /* Hinweis-Banner: Gold-Glas mit skewed "!"-Marke */
  .notice {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-top: 28px;
    padding: 12px 18px;
    border-radius: 14px;
    background: rgba(232, 201, 106, 0.09);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(232, 201, 106, 0.3);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--gold);
  }
  .notice::before {
    content: '!';
    flex: none;
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--bg);
    background: var(--gold);
    padding: 2px 8px;
    transform: skewX(-12deg);
  }

  /* KPI-Kacheln (Bilanz, Spieltags-Kopf) */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin: 26px 0 8px;
  }
  .stat-tile {
    padding: 20px 24px;
    border-radius: var(--r-panel);
    background: rgba(255, 255, 255, 0.055);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-highlight), 0 12px 32px rgba(0, 0, 0, 0.35);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .stat-tile:hover {
    transform: translateY(-3px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 18px 44px rgba(0, 0, 0, 0.45), 0 0 28px rgba(212, 255, 63, 0.1);
  }
  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 38px;
    font-style: italic;
    color: var(--text);
  }
  .stat-value.accent { color: var(--lime); text-shadow: 0 0 24px rgba(212, 255, 63, 0.35); }
  .stat-label {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Vergleichsbalken (Bilanz): unskewed, Farbe je Serie */
  .bar-chart { display: flex; flex-direction: column; gap: 10px; margin: 18px 0 24px; }
  .bar-row {
    display: grid; grid-template-columns: minmax(120px, 190px) 1fr auto;
    align-items: center; gap: 12px; font-size: 13px; font-weight: 600; color: var(--text-muted);
  }
  .bar-row.is-highlight .bar-name, .bar-row.is-highlight .bar-value { color: var(--lime); }
  .bar-track { position: relative; height: 10px; border-radius: 999px; background: rgba(255, 255, 255, 0.06); }
  .bar-fill {
    position: absolute; inset: 0; width: var(--pct, 0%); border-radius: 999px;
    background: var(--bar-color, var(--lime));
    box-shadow: 0 0 12px -2px var(--bar-color, var(--accent-glow));
  }
  .bar-row .bar-value { font-variant-numeric: tabular-nums; color: var(--text); white-space: nowrap; }

  /* Tabellen (Archiv, Bilanz) */
  .table-wrap {
    overflow: auto;
    border-radius: var(--r-panel);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  table { border-collapse: collapse; width: 100%; font-size: 13.5px; }
  th, td { border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 10px 14px; text-align: left; }
  tr:last-child td { border-bottom: none; }
  th {
    background: rgba(255, 255, 255, 0.03); color: var(--text-muted);
    font-weight: 700; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
  }
  tbody tr { transition: background 0.15s ease; }
  tbody tr:hover td { background: rgba(255, 255, 255, 0.03); }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }

  pre {
    background: var(--surface-solid);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-panel);
    padding: 14px 16px;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
  }
  code { font-family: var(--font-mono); }
</style>
