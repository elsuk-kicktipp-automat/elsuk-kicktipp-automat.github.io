---
const { title = 'Der Automat' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { href: `${base}/`, label: 'Spieltag' },
  { href: `${base}/archiv/`, label: 'Archiv' },
  { href: `${base}/bilanz/`, label: 'Bilanz' },
  { href: `${base}/wie-ich-denke/`, label: 'Wie ich denke' },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#05070a" />
    <title>{title} · Der Automat</title>
    <meta
      name="description"
      content="Der Automat: ein statistischer KI-Tipper für die Kicktipp-Runde – transparent, versiegelt, nachrechenbar."
    />
   <script defer src="https://cloud.umami.is/script.js" data-website-id="b7788806-f762-4f1d-902e-fce55d0b8c04"></script>
  </head>
  <body>
    <div class="aurora" aria-hidden="true"></div>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}/`}><span class="brand-mark">⚙️</span> Der Automat</a>
        <nav>
          {nav.map((item) => (
            <a href={item.href} class:list={{ active: current === item.href }}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>
          Maschinell getippt, menschlich verlierbar. Quellcode &amp; Daten:
          <a href="https://github.com/elsuk-kicktipp-automat/der-automat">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --font-sans: system-ui, -apple-system, 'Segoe UI Variable', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: ui-monospace, 'SF Mono', 'Cascadia Code', 'JetBrains Mono', Consolas, 'Liberation Mono', monospace;

    /* Dunkles Daten-Dashboard ist der Standard, nicht nur ein prefers-color-scheme-Ableger */
    --bg: #05070a;
    --bg-2: #0a0e14;
    --surface: rgba(255, 255, 255, 0.05);
    --surface-2: rgba(255, 255, 255, 0.03);
    --surface-solid: #10141c;
    --border: rgba(255, 255, 255, 0.1);
    --text: #f2f5f8;
    --muted: #9aa5b1;
    --sealed: #7c8794;

    --accent: #4cc394;
    --accent-strong: #7fe0b8;
    --accent-glow: rgba(76, 195, 148, 0.35);
    --accent-soft: rgba(76, 195, 148, 0.14);

    /* Kategoriale Vergleichsfarben (Schattentipper, Punkte-Tiers) + diverging Heim/Remis/Auswärts */
    --series-blue: #3987e5;
    --series-amber: #c98500;
    --series-red: #e66767;
    --series-gray: #6b7683;

    --p4: var(--accent);
    --p3: var(--series-blue);
    --p2: var(--series-amber);
    --p0: var(--series-red);

    --aurora-opacity: 0.9;
  }

  @media (prefers-color-scheme: light) {
    :root {
      color-scheme: light;
      --bg: #f5f7f9;
      --bg-2: #eceff2;
      --surface: rgba(255, 255, 255, 0.7);
      --surface-2: rgba(11, 15, 20, 0.04);
      --surface-solid: #ffffff;
      --border: rgba(11, 15, 20, 0.1);
      --text: #12161c;
      --muted: #5b6b7b;
      --sealed: #7c8794;

      --accent: #0b6e4f;
      --accent-strong: #085c41;
      --accent-glow: rgba(11, 110, 79, 0.22);
      --accent-soft: rgba(11, 110, 79, 0.1);

      --series-blue: #2a78d6;
      --series-amber: #b07d2a;
      --series-red: #c0392b;
      --series-gray: #8b93a1;

      --aurora-opacity: 0.3;
    }
  }

  * { box-sizing: border-box; }

  html { background: var(--bg); }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::selection { background: var(--accent-glow); color: var(--text); }

  * { scrollbar-color: var(--accent) transparent; scrollbar-width: thin; }
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

  a:focus-visible, button:focus-visible, [tabindex]:focus-visible, summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Aurora-Hintergrund: fixe, weich verlaufende Farbflächen hinter dem Inhalt.
     Größer als der Viewport + transform-Animation, damit sie GPU-beschleunigt
     driftet, ohne Ränder freizugeben. */
  .aurora {
    position: fixed;
    inset: -20%;
    width: 140%;
    height: 140%;
    z-index: -1;
    pointer-events: none;
    opacity: var(--aurora-opacity);
    background:
      radial-gradient(38% 30% at 22% 22%, var(--accent-glow), transparent 70%),
      radial-gradient(32% 28% at 82% 12%, rgba(57, 135, 229, 0.22), transparent 70%),
      radial-gradient(40% 34% at 65% 88%, rgba(230, 103, 103, 0.12), transparent 70%);
    filter: blur(60px);
    animation: aurora-drift 40s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes aurora-drift {
    0% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-3%, 2%, 0) scale(1.06); }
    100% { transform: translate3d(2%, -3%, 0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .aurora { animation: none; }
  }

  .container { max-width: 880px; margin: 0 auto; padding: 0 1rem; }

  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex; flex-wrap: wrap; gap: 0.25rem 1.5rem;
    align-items: center; justify-content: space-between; padding: 0.75rem 1rem;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-weight: 800; font-size: 1.15rem; letter-spacing: -0.01em;
    color: var(--text); text-decoration: none;
  }
  .brand-mark { filter: drop-shadow(0 0 10px var(--accent-glow)); }
  nav { display: flex; flex-wrap: wrap; gap: 0.25rem 1.35rem; }
  nav a {
    position: relative;
    color: var(--muted); text-decoration: none; font-weight: 500;
    padding: 0.3rem 0.05rem; transition: color 0.2s ease;
  }
  nav a::after {
    content: ''; position: absolute; left: 0; right: 100%; bottom: -3px; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-strong));
    border-radius: 2px; transition: right 0.25s ease;
  }
  nav a:hover, nav a.active { color: var(--text); }
  nav a:hover::after, nav a.active::after { right: 0; }

  main { padding: 1.6rem 1rem 3.5rem; }
  footer { border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
  footer .container { padding: 1.1rem 1rem; }
  a { color: var(--accent-strong); }

  h1 {
    font-size: clamp(1.6rem, 1.1rem + 2.2vw, 2.5rem);
    font-weight: 800; letter-spacing: -0.02em;
    margin: 0.5rem 0 0.35rem; color: var(--text);
  }
  @supports (background-clip: text) {
    h1 {
      background: linear-gradient(135deg, var(--text) 25%, var(--accent-strong) 120%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
  }
  h2 {
    font-size: 1.2rem; font-weight: 700; letter-spacing: -0.01em;
    margin-top: 2.3rem; margin-bottom: 0.7rem; padding-left: 0.65rem;
    border-left: 3px solid var(--accent); color: var(--text);
  }
  .muted { color: var(--muted); }

  /* Glaskarte mit 3D-Tilt: nur bei echtem Zeigegerät (Desktop), auf Touch
     bleibt die Karte flach – keine unabsichtlichen Sticky-Hover-Effekte. */
  .card {
    background: linear-gradient(160deg, var(--surface), var(--surface-2));
    backdrop-filter: blur(14px) saturate(130%);
    -webkit-backdrop-filter: blur(14px) saturate(130%);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.1rem 1.25rem;
    margin: 0.8rem 0;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04) inset, 0 16px 32px -26px rgba(0, 0, 0, 0.7);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s ease, border-color 0.35s ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .card:hover {
      transform: perspective(900px) rotateX(2deg) rotateY(-1.5deg) translateY(-4px);
      border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
      box-shadow: 0 22px 44px -24px var(--accent-glow), 0 6px 16px -8px rgba(0, 0, 0, 0.6);
    }
  }

  .match-head {
    display: flex; flex-wrap: wrap; gap: 0.25rem 1rem;
    align-items: baseline; justify-content: space-between;
  }
  .pairing { font-weight: 700; font-size: 1.08rem; letter-spacing: -0.01em; color: var(--text); }
  .kickoff { color: var(--muted); font-size: 0.82rem; white-space: nowrap; font-variant-numeric: tabular-nums; }

  .tip {
    display: inline-flex; align-items: baseline;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 22%, transparent), color-mix(in srgb, var(--accent) 6%, transparent));
    color: var(--accent-strong);
    font-weight: 800; font-size: 1.35rem; letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    border: 1px solid color-mix(in srgb, var(--accent) 32%, transparent);
    border-radius: 10px; padding: 0.2rem 0.75rem; margin: 0.45rem 0;
  }

  .badge {
    display: inline-flex; align-items: center; gap: 0.3rem;
    border-radius: 999px; font-size: 0.76rem; font-weight: 700;
    letter-spacing: 0.01em; padding: 0.2rem 0.65rem; vertical-align: middle;
    border: 1px solid transparent;
  }
  .badge.sealed { background: var(--surface-2); color: var(--muted); border-color: var(--border); }
  .badge.info {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    color: var(--accent-strong);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .badge.p4, .badge.p3, .badge.p2, .badge.p0 {
    background: color-mix(in srgb, var(--badge-color) 20%, transparent);
    color: var(--badge-color);
    border-color: color-mix(in srgb, var(--badge-color) 45%, transparent);
  }
  .badge.p4 { --badge-color: var(--p4); }
  .badge.p3 { --badge-color: var(--p3); }
  .badge.p2 { --badge-color: var(--p2); }
  .badge.p0 { --badge-color: var(--p0); }

  .hash {
    font-family: var(--font-mono); font-size: 0.76rem; word-break: break-all;
    color: var(--muted); background: var(--surface-2);
    padding: 0.45rem 0.6rem; border-radius: 8px; display: inline-block;
  }
  .notice {
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 14%, transparent), color-mix(in srgb, var(--series-amber) 8%, transparent));
    border: 1px solid var(--border);
    border-radius: 12px; padding: 0.65rem 0.9rem; font-size: 0.88rem; color: var(--muted);
    backdrop-filter: blur(10px);
  }
  .factors { color: var(--muted); font-size: 0.85rem; margin: 0.35rem 0 0.5rem; }
  details { margin-top: 0.6rem; font-size: 0.85rem; color: var(--muted); }
  details summary { cursor: pointer; color: var(--accent-strong); font-weight: 600; }
  details code { font-family: var(--font-mono); font-size: 0.78rem; word-break: break-all; }

  /* Diverging Heim/Remis/Auswärts-Balken: blau ↔ grau ↔ rot, 2px Fugen */
  .prob-bar {
    display: flex; gap: 2px; height: 8px; border-radius: 999px;
    overflow: hidden; background: var(--surface-2); margin: 0.55rem 0 0.35rem;
  }
  .prob-bar span { display: block; height: 100%; }
  .prob-bar .p-home { background: var(--series-blue); border-radius: 999px 0 0 999px; }
  .prob-bar .p-draw { background: var(--series-gray); }
  .prob-bar .p-away { background: var(--series-red); border-radius: 0 999px 999px 0; }

  /* KPI-Kacheln (Bilanz, Spieltags-Kopf) */
  .stat-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.7rem; margin: 1rem 0 1.7rem;
  }
  .stat-tile {
    background: linear-gradient(160deg, var(--surface), var(--surface-2));
    backdrop-filter: blur(14px);
    border: 1px solid var(--border); border-radius: 14px; padding: 0.9rem 1rem;
  }
  .stat-value {
    display: block; font-size: 1.7rem; font-weight: 800; letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums; color: var(--text);
  }
  .stat-value.accent { color: var(--accent-strong); }
  .stat-label { display: block; margin-top: 0.15rem; font-size: 0.78rem; color: var(--muted); }
  @supports (animation-timeline: view()) {
    .stat-tile {
      animation: reveal-up linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 30%;
    }
  }
  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .stat-tile { animation: none !important; }
  }

  /* Handgebaute horizontale Balken (Bilanz-Vergleiche): dünne Marke,
     abgerundete Enden, eigene Spur pro Zeile */
  .bar-chart { display: flex; flex-direction: column; gap: 0.55rem; margin: 1rem 0 1.5rem; }
  .bar-row {
    display: grid; grid-template-columns: minmax(120px, 190px) 1fr auto;
    align-items: center; gap: 0.7rem; font-size: 0.85rem;
  }
  .bar-row .bar-name { color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .bar-row.is-highlight .bar-name, .bar-row.is-highlight .bar-value { color: var(--accent-strong); font-weight: 700; }
  .bar-track { position: relative; height: 10px; border-radius: 999px; background: var(--surface-2); }
  .bar-fill {
    position: absolute; inset: 0; width: var(--pct, 0%); border-radius: 999px;
    background: var(--bar-color, var(--accent));
    box-shadow: 0 0 12px -2px var(--bar-color, var(--accent-glow));
  }
  .bar-row .bar-value { font-variant-numeric: tabular-nums; font-weight: 700; color: var(--text); white-space: nowrap; }

  .table-wrap { overflow: auto; border-radius: 14px; border: 1px solid var(--border); }
  table { border-collapse: collapse; width: 100%; background: var(--surface-solid); font-size: 0.88rem; }
  th, td { border-bottom: 1px solid var(--border); padding: 0.55rem 0.7rem; text-align: left; }
  tr:last-child td { border-bottom: none; }
  th {
    background: var(--surface-2); color: var(--muted); font-weight: 700;
    font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.04em;
  }
  tbody tr { transition: background 0.15s ease; }
  tbody tr:hover td { background: var(--surface-2); }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }

  pre {
    background: var(--surface-solid); border: 1px solid var(--border); border-radius: 12px;
    padding: 0.9rem 1rem; overflow-x: auto; font-family: var(--font-mono); font-size: 0.82rem;
    color: var(--muted);
  }
  code { font-family: var(--font-mono); }

  /* Zwischenbreiten: zweispaltige Karten ab Tablet, nicht erst am Desktop */
  @media (min-width: 640px) {
    .match-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
    .match-grid .card { margin: 0; }
  }
  @media (min-width: 1000px) {
    .container { max-width: 1000px; }
  }
</style>
