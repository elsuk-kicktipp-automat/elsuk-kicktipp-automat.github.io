---
import { formatKickoff } from '../lib/data.mjs';

// match: Eintrag aus data/matchdays/*.json, scored: passender Eintrag aus data/results/
const { match, scored, delay = 0 } = Astro.props;
const sealed = match.status === 'sealed';
const factors = match.factors ?? {};
const probs = factors.probabilities;
const xg = factors.expected_goals;
const market = factors.market;
const elo = factors.elo;
const hasElo = elo?.home != null && elo?.away != null;
const eloDiff = hasElo ? Math.round(elo.home - elo.away) : null;
const llmAdjustment = factors.llm_adjustment;
const newsChecked = factors.news_checked;
const newsSources = factors.news_sources;
const checkedNewsSources = newsSources?.sources?.filter((source) => source.checked) ?? [];
const failedNewsSources = newsSources?.sources?.filter((source) => !source.checked) ?? [];
const newsSourceLabels = checkedNewsSources.map((source) => source.label).join(', ');
const newsHitsBySource = checkedNewsSources
  .filter((source) => source.matches > 0)
  .map((source) => `${source.label}: ${source.matches}`)
  .join(' · ');
const pointsClass = scored ? `p${scored.points}` : '';
const paperBet = match.paper_bet;
const paperBetResult = scored?.paper_bet_result;
const money = new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR' });
const stake = paperBet?.stake_eur ?? 0;
const possibleProfit = paperBet?.odds_decimal ? stake * (paperBet.odds_decimal - 1) : null;
const possibleLoss = stake > 0 ? -stake : null;
---

<article class="match-card" style={`animation-delay:${delay}ms`}>
  <div class="match-head">
    <span class="match-title">{match.home} <span class="sep">–</span> {match.away}</span>
    <span class="match-kickoff">{formatKickoff(match.kickoff_utc)}</span>
  </div>

  {sealed ? (
    <div class="sealed-block">
      <span class="badge badge-muted">🔒 Tipp abgegeben, versiegelt</span>
      {match.paper_bet_status === 'sealed' && <span class="badge badge-muted">💶 Paper-Wette versiegelt</span>}
      <p class="hash" title="SHA-256 der versiegelten Tipp-Payload">{match.hash}</p>
      <p class="sealed-note">Der Tipp steht fest und wird nach Anstoß enthüllt – der Hash beweist es.</p>
    </div>
  ) : (
    <>
      <div class="match-tip-row">
        <span class="tip-chip"><span>{match.tip[0]}:{match.tip[1]}</span></span>
        {scored && (
          <>
            <span class="result">Ergebnis <b>{scored.result[0]}:{scored.result[1]}</b></span>
            <span class:list={['badge', 'badge-points', pointsClass]}>{scored.points} Punkte</span>
          </>
        )}
        {match.advance_tip && (
          <span class="badge badge-lime" title="Zusatzfrage: Sieger im Elfmeterschießen bei Remis nach 90 Minuten">
            🥅 Elfmeterschießen: {match.advance_tip.pick} ({Math.round(match.advance_tip.probability * 100)} %)
          </span>
        )}
      </div>

      {probs && xg && (
        <div class="probs">
          <div
            class="prob-bar"
            role="img"
            aria-label={`Heimsieg ${Math.round(probs.home * 100)} Prozent, Remis ${Math.round(probs.draw * 100)} Prozent, Auswärtssieg ${Math.round(probs.away * 100)} Prozent`}
          >
            <span class="bar bar-home" style={`width:${probs.home * 100}%`}></span>
            <span class="bar bar-draw" style={`width:${probs.draw * 100}%`}></span>
            <span class="bar bar-away" style={`width:${probs.away * 100}%`}></span>
          </div>
          <div class="prob-legend">
            <span><i class="dot dot-home"></i> Heim {Math.round(probs.home * 100)} %</span>
            <span><i class="dot dot-draw"></i> Remis {Math.round(probs.draw * 100)} %</span>
            <span><i class="dot dot-away"></i> Auswärts {Math.round(probs.away * 100)} %</span>
            <span class="xg">xG {xg[0]} : {xg[1]}</span>
          </div>
        </div>
      )}

      {match.begruendung && <p class="analysis">{match.begruendung}</p>}
      {match.begruendung_source === 'llm' && (
        <p class="source-tag" title="Begründungstext von einem LLM formuliert, nicht der Tipp selbst">
          🤖 Begründung von der KI-Analyseschicht formuliert
        </p>
      )}

      {paperBet && (
        <div class:list={['bet-box', paperBetResult?.profit_eur > 0 ? 'is-win' : paperBetResult?.profit_eur < 0 ? 'is-loss' : '']}>
          <div class="bet-head">
            <span class="bet-title">Paper-Wette</span>
            <span class="bet-source">{paperBet.source_label ?? 'keine Quote'}</span>
          </div>
          <div class="bet-grid">
            <span>
              <b>{paperBet.selection_label}</b>
              <small>Auswahl</small>
            </span>
            <span>
              <b>{paperBet.odds_decimal ? paperBet.odds_decimal.toFixed(2) : '–'}</b>
              <small>Quote</small>
            </span>
            <span>
              <b>{money.format(paperBet.stake_eur ?? 0)}</b>
              <small>Einsatz</small>
            </span>
            {paperBetResult ? (
              <span>
                <b>{money.format(paperBetResult.profit_eur)}</b>
                <small>Ergebnis</small>
              </span>
            ) : (
              <span>
                <b>{possibleProfit != null ? money.format(possibleProfit) : '–'}</b>
                <small>Gewinn wenn richtig</small>
              </span>
            )}
          </div>
          {paperBetResult ? (
            <p class="bet-note">
              {paperBetResult.outcome === 'won'
                ? <>Die Paper-Wette hat gewonnen: netto {money.format(paperBetResult.profit_eur)}.</>
                : paperBetResult.outcome === 'lost'
                  ? <>Die Paper-Wette hat verloren: netto {money.format(paperBetResult.profit_eur)}.</>
                  : <>Es wurde keine Paper-Wette mit Einsatz gespielt.</>}
            </p>
          ) : stake > 0 && possibleProfit != null && possibleLoss != null ? (
            <p class="bet-note">
              Wenn {paperBet.selection_label} stimmt: {money.format(possibleProfit)} Gewinn netto.
              Wenn nicht: {money.format(possibleLoss)} Verlust.
              {paperBet.edge != null && <> Einschätzung der Wette: {paperBet.edge >= 0 ? 'leicht positiv' : 'eher riskant'}.</>}
            </p>
          ) : (
            <p class="bet-note">
              Keine Paper-Wette mit Einsatz, weil keine passende Quote oder kein rechnerischer Vorteil vorlag.
            </p>
          )}
        </div>
      )}

      <div class="sources">
        <div class="sources-title">Quellen &amp; Faktoren</div>
        <ul class="sources-list">
          <li>
            Statistisches Modell (Dixon-Coles-Poisson)
            {factors.trained_on_matches != null && <> · trainiert auf {factors.trained_on_matches} Spielen</>}
          </li>
          {hasElo && (
            <li>
              ELO-Bewertung: {match.home} {Math.round(elo.home)} · {match.away} {Math.round(elo.away)}
              {' '}(Differenz {eloDiff > 0 ? '+' : ''}{eloDiff})
            </li>
          )}
          {market && (
            <li>
              Buchmacherquoten ({Math.round(market.weight * 100)} % Gewicht): Heim {Math.round(market.home * 100)} % ·
              Remis {Math.round(market.draw * 100)} % · Auswärts {Math.round(market.away * 100)} %
            </li>
          )}
          {llmAdjustment ? (
            <li>
              News-Check: {llmAdjustment.news_count} Schlagzeile{llmAdjustment.news_count === 1 ? '' : 'n'} geprüft –
              Schattenvorschlag {llmAdjustment.tip[0]}:{llmAdjustment.tip[1]} ({llmAdjustment.grund}), nicht übernommen
              {newsSourceLabels && <> · Quellen: {newsSourceLabels}</>}
            </li>
          ) : newsChecked != null ? (
            <li>
              News-Check: {newsChecked > 0
                ? `${newsChecked} passende Meldung${newsChecked === 1 ? '' : 'en'} gefunden`
                : 'keine passende Meldung gefunden'}
              {newsSourceLabels && <> · Quellen: {newsSourceLabels}</>}
              {newsHitsBySource && <> · Treffer: {newsHitsBySource}</>}
              {failedNewsSources.length > 0 && <> · nicht erreichbar: {failedNewsSources.map((source) => source.label).join(', ')}</>}
            </li>
          ) : null}
        </ul>
      </div>

      {match.salt && match.hash && (
        <details class="reveal-proof">
          <summary>Fairness-Beweis nachrechnen</summary>
          <p>Salt: <code>{match.salt}</code></p>
          <p>Hash: <code>{match.hash}</code></p>
          <p>Anleitung: siehe „Wie ich denke".</p>
        </details>
      )}
    </>
  )}
</article>

<style>
  .match-card {
    border-radius: var(--r-card);
    background: var(--glass-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-highlight), var(--shadow-card);
    padding: 0 0 22px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    animation: riseIn 0.5s both;
  }
  .match-card:hover {
    transform: perspective(1000px) rotateX(1.5deg) translateY(-5px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2), var(--shadow-card-hover);
  }

  .match-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    padding: 16px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.03);
  }
  .match-title {
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .match-title .sep { color: var(--text-muted); }
  .match-kickoff { font-size: 12px; font-weight: 600; color: var(--text-muted); letter-spacing: 0.06em; }

  .match-tip-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    padding: 18px 22px 4px;
  }
  .tip-chip {
    background: var(--lime);
    color: var(--bg);
    transform: skewX(-12deg);
    padding: 6px 16px;
    box-shadow: var(--glow-lime);
  }
  .tip-chip span {
    display: inline-block;
    transform: skewX(12deg);
    font-family: var(--font-display);
    font-size: 26px;
  }
  .result { font-size: 14px; color: var(--text-muted); }
  .result b { color: var(--text); }

  .badge {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: var(--r-badge);
  }
  .badge-points.p4, .badge-points.p3, .badge-points.p2 {
    color: var(--gold);
    border: 1px solid rgba(232, 201, 106, 0.4);
    background: rgba(232, 201, 106, 0.08);
  }
  .badge-points.p0 {
    color: var(--red);
    border: 1px solid rgba(255, 77, 94, 0.4);
    background: rgba(255, 77, 94, 0.08);
  }
  .badge-lime {
    color: var(--lime);
    border: 1px solid rgba(212, 255, 63, 0.35);
    background: rgba(212, 255, 63, 0.07);
  }
  .badge-muted {
    color: var(--text-muted);
    border: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.04);
  }

  .probs { padding: 16px 22px 0; }
  .prob-bar { display: flex; height: 8px; gap: 2px; }
  .bar { transform: skewX(-24deg); }
  .bar-home { background: var(--lime); box-shadow: 0 0 12px rgba(212, 255, 63, 0.4); }
  .bar-draw { background: rgba(255, 255, 255, 0.18); }
  .bar-away { background: var(--red); }
  .prob-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 9px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
  }
  .dot { display: inline-block; width: 9px; height: 9px; }
  .dot-home { background: var(--lime); }
  .dot-draw { background: #8b93a5; }
  .dot-away { background: var(--red); }
  .xg { margin-left: auto; }

  .analysis { margin: 16px 22px 0; font-size: 13.5px; line-height: 1.6; color: var(--text-body); }
  .source-tag { margin: 8px 22px 0; font-size: 11.5px; color: var(--text-muted); font-style: italic; }

  .bet-box {
    margin: 14px 22px 0;
    padding: 12px 14px;
    border-radius: var(--r-panel);
    background: rgba(63, 140, 255, 0.06);
    border: 1px solid rgba(63, 140, 255, 0.28);
  }
  .bet-box.is-win {
    background: rgba(212, 255, 63, 0.07);
    border-color: rgba(212, 255, 63, 0.32);
  }
  .bet-box.is-loss {
    background: rgba(255, 77, 94, 0.07);
    border-color: rgba(255, 77, 94, 0.32);
  }
  .bet-head {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: baseline;
    margin-bottom: 10px;
  }
  .bet-title {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .bet-source { font-size: 11.5px; color: var(--text-muted); }
  .bet-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }
  .bet-grid span { min-width: 0; }
  .bet-grid b {
    display: block;
    font-size: 14px;
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .bet-grid small {
    display: block;
    margin-top: 2px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .bet-note { margin: 10px 0 0; font-size: 11.5px; color: var(--text-muted); }

  .sources {
    margin: 14px 22px 0;
    padding: 12px 14px;
    border-radius: var(--r-panel);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--glass-border);
  }
  .sources-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .sources-list {
    margin: 0;
    padding-left: 1.1em;
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-body);
  }
  .sources-list li { margin: 2px 0; }

  .reveal-proof {
    margin: 14px 22px 0;
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .reveal-proof summary { cursor: pointer; color: var(--lime); font-weight: 600; }
  .reveal-proof code { font-family: var(--font-mono); font-size: 11.5px; word-break: break-all; }

  .sealed-block { padding: 16px 22px 0; }
  .sealed-block .badge-muted { display: inline-block; }
  .hash {
    font-family: var(--font-mono);
    font-size: 11.5px;
    word-break: break-all;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--glass-border);
    padding: 8px 10px;
    border-radius: 8px;
    margin: 12px 0 0;
  }
  .sealed-note { font-size: 12.5px; color: var(--text-muted); margin: 10px 0 0; }

  @media (max-width: 620px) {
    .bet-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
