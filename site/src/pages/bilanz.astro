---
import Layout from '../layouts/Layout.astro';
import { loadBacktest, loadResults } from '../lib/data.mjs';

const club = loadBacktest('club');
const national = loadBacktest('national');

// Live-Bilanz des laufenden Betriebs aus den Abrechnungen
const live = [...loadResults().values()].sort((a, b) => a.matchday - b.matchday);
const liveTotal = live.reduce((s, r) => s + r.points_total, 0);
const liveScored = live.reduce((s, r) => s + r.matches_scored, 0);

// Schatten-Summen nur, wenn der Tipper in allen gewerteten Spielen mitlief
function sumShadow(name: string): number | null {
  const rows = live.filter((r) => r.matches_scored > 0);
  if (!rows.every((r) => r.shadow_matches?.[name] === r.matches_scored)) return null;
  return rows.reduce((s: number, r) => s + (r.shadow_points?.[name] ?? 0), 0);
}
---

<Layout title="Bilanz">
  <h1>Bilanz</h1>

  <h2>Laufender Betrieb (WM 2026)</h2>
  {liveScored === 0 ? (
    <p class="muted">Noch keine gewerteten Spiele – die Abrechnung folgt nach den Anstößen.</p>
  ) : (
    <>
      <p class="muted">
        Neben dem Automaten laufen drei Schattentipper mit: das wahrscheinlichste
        Einzelergebnis (statt EV-Optimierung), immer 2:1 für den ELO-Favoriten
        und immer 1:1. Brier misst die Kalibrierung der Wahrscheinlichkeiten
        (kleiner = besser).
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Runde</th><th class="num">Spiele</th>
              <th class="num">Automat</th><th class="num">wahrsch. Ergebnis</th>
              <th class="num">ELO-Favorit 2:1</th><th class="num">immer 1:1</th>
              <th class="num">Ø Brier</th>
            </tr>
          </thead>
          <tbody>
            {live.filter((r) => r.matches_scored > 0).map((r) => (
              <tr>
                <td>{r.stage}</td>
                <td class="num">{r.matches_scored}</td>
                <td class="num"><strong>{r.points_total}</strong></td>
                <td class="num">{r.shadow_points?.most_probable ?? '–'}</td>
                <td class="num">{r.shadow_points?.elo_favorite ?? '–'}</td>
                <td class="num">{r.shadow_points?.always_draw ?? '–'}</td>
                <td class="num">{r.brier_avg?.toFixed(3) ?? '–'}</td>
              </tr>
            ))}
            <tr>
              <td><strong>Gesamt</strong></td>
              <td class="num"><strong>{liveScored}</strong></td>
              <td class="num"><strong>{liveTotal}</strong></td>
              <td class="num"><strong>{sumShadow('most_probable') ?? '–'}</strong></td>
              <td class="num"><strong>{sumShadow('elo_favorite') ?? '–'}</strong></td>
              <td class="num"><strong>{sumShadow('always_draw') ?? '–'}</strong></td>
              <td class="num"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </>
  )}

  <h2>Backtests</h2>
  <p class="muted">
    Simulierter Tippbetrieb: Vor jeder Runde wird nur auf bis dahin gespielten Partien
    trainiert. Baselines: (a) immer 2:1 für den ELO-Favoriten, (b) immer 1:1.
  </p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Backtest</th><th class="num">Spiele</th><th class="num">Punkte</th>
          <th class="num">Ø/Spiel</th><th class="num">ELO-Favorit 2:1</th><th class="num">immer 1:1</th>
        </tr>
      </thead>
      <tbody>
        {club?.seasons.map((s) => (
          <tr>
            <td>Bundesliga {s.season}/{String(s.season + 1).slice(-2)}</td>
            <td class="num">{s.matches}</td>
            <td class="num">{s.points}</td>
            <td class="num">{s.points_per_match.toFixed(3)}</td>
            <td class="num">{s.baseline_elo_points}</td>
            <td class="num">{s.baseline_draw_points}</td>
          </tr>
        ))}
        {club && (
          <tr>
            <td><strong>Bundesliga gesamt</strong></td>
            <td class="num"><strong>{club.total.matches}</strong></td>
            <td class="num"><strong>{club.total.points}</strong></td>
            <td class="num"><strong>{club.total.points_per_match.toFixed(3)}</strong></td>
            <td class="num"><strong>{club.total.baseline_elo_points}</strong></td>
            <td class="num"><strong>{club.total.baseline_draw_points}</strong></td>
          </tr>
        )}
        {national && (
          <tr>
            <td><strong>WM 2026 (out-of-sample)</strong></td>
            <td class="num"><strong>{national.total.matches}</strong></td>
            <td class="num"><strong>{national.total.points}</strong></td>
            <td class="num"><strong>{national.total.points_per_match.toFixed(3)}</strong></td>
            <td class="num"><strong>{national.total.baseline_elo_points}</strong></td>
            <td class="num"><strong>{national.total.baseline_draw_points}</strong></td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
  <p class="muted" style="font-size:0.85rem">
    Hinweis zum WM-Backtest: eloratings.net liefert nur aktuelle Ratings, die
    Retro-Zahlen tragen daher einen leichten Lookahead-Bias – für künftige
    Tipps irrelevant.
  </p>
</Layout>
